# PostgreSQL — copier vers backend/.env
# Neon : collez l'URL avec ?sslmode=require
# Vercel : préférer l'URL « pooler » Neon (host *-pooler.*.neon.tech) pour le serverless
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

SECRET_KEY=dev-secret-key-change-in-production
# Prod/Vercel : SECRET_KEY fort obligatoire (≥24 chars, pas le défaut)
COOKIE_SECURE=false
FRONTEND_URL=http://localhost:5173
APP_NAME=Super
ENVIRONMENT=development
# DEBUG en local — INFO en prod/Vercel
LOG_LEVEL=DEBUG

# Brevo (e-mails transactionnels) — https://www.brevo.com/
# BREVO_API_KEY=xkeysib-xxxx
# BREVO_SENDER_EMAIL=noreply@votre-domaine.fr
# BREVO_SENDER_NAME=Super
BREVO_USE_SIMULATION=true
# BREVO_SANDBOX_RECIPIENT=votre-email@test.com
EMAIL_VERIFY_EXPIRE_HOURS=48

# --- Production Vercel + Neon ---
# 1. Créer une base Neon (https://neon.tech) et copier DATABASE_URL (pooler recommandé)
# 2. Migrations (depuis backend/) — base Neon VIERGE :
#      python scripts/init_neon_db.py
#    Si « alembic upgrade head » échoue après a001 (colonne déjà existante) :
#      python -m alembic stamp head
# 3. Admin initial (depuis backend/) :
#      python scripts/create_initial_admin.py
# 4. Donnees demo production (Neon/Vercel — avec --confirm) :
#      python scripts/seed_demo_data.py --confirm
# 4. Variables Vercel (Settings → Environment Variables) :
#      DATABASE_URL, SECRET_KEY, FRONTEND_URL=https://votre-app.vercel.app
#      COOKIE_SECURE=true, BREVO_* (désactiver BREVO_USE_SIMULATION)
#      BLOB_READ_WRITE_TOKEN (Storage → Blob → token), CRON_SECRET
# 5. Déployer : vercel (ou connecter le repo GitHub à Vercel)

# --- Vercel Blob (médias persistants) ---
# https://vercel.com/docs/storage/vercel-blob
# Sans token : repli sur le disque local (backend/uploads) — OK en dev uniquement
BLOB_READ_WRITE_TOKEN=
# "private" (défaut, store privé) ou "public" — doit matcher le store Vercel
BLOB_ACCESS=private
# TTL après validation menahel (heures) — photos/vidéos/audios référence + clôture
MEDIA_RETENTION_HOURS=24
MEDIA_PHOTO_MAX_EDGE_PX=1280
MEDIA_PHOTO_QUALITY=65
# Protège GET/POST /api/cron/purge-media (Vercel Cron envoie Authorization: Bearer …)
CRON_SECRET=

# --- Fournisseur AI (gemini | opencode) ---
AI_PROVIDER=gemini

# Google Gemini — https://aistudio.google.com/apikey
# נדרש גם לעיבוד הודעות קוליות (יצירת משימות)
# Vercel : GEMINI_API_KEY dans Settings → Environment Variables
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-2.5-flash-lite
GEMINI_GENERATION_FALLBACK_MODELS=gemini-2.0-flash,gemini-2.5-flash-lite
GEMINI_RETRY_COUNT=2
GEMINI_RETRY_DELAY_SECONDS=2
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_GENERATION_MAX_OUTPUT_TOKENS=8192
GEMINI_GENERATION_TIMEOUT_SECONDS=120
GEMINI_THINKING_BUDGET=0

# OpenCode Go — https://opencode.ai/go
#
# Production (Vercel) : OPENCODE_API_KEY + OPENCODE_API_BASE_URL (pas de serveur local)
# Dev local : OPENCODE_API_KEY vide + opencode serve --port 4096 + OPENCODE_SERVER_URL
OPENCODE_API_KEY=
OPENCODE_API_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_SERVER_URL=http://127.0.0.1:4096
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=
OPENCODE_PROVIDER_ID=opencode-go
OPENCODE_MODEL_ID=deepseek-v4-flash
OPENCODE_AGENT=build
OPENCODE_TIMEOUT_SECONDS=240
OPENCODE_RETRY_COUNT=2
OPENCODE_RETRY_DELAY_SECONDS=2

# --- Google Cloud — traduction + TTS employé (arabe, thaï, etc.) ---
# Activer Cloud Translation API + Cloud Text-to-Speech API sur le projet GCP
# Créer une clé API avec accès aux deux services
GOOGLE_CLOUD_API_KEY=
# Repli uniquement si la langue de l'auteur (manager) est inconnue — sinon preferred_language
GOOGLE_TRANSLATE_SOURCE=he
GOOGLE_TTS_VOICE_AR=ar-XA-Wavenet-B
GOOGLE_TTS_VOICE_TH=th-TH-Neural2-C
GOOGLE_TTS_VOICE_FR=fr-FR-Neural2-A
GOOGLE_TTS_VOICE_EN=en-US-Neural2-C
GOOGLE_TTS_VOICE_HE=he-IL-Wavenet-A
GOOGLE_TTS_AUDIO_ENCODING=MP3
GOOGLE_TTS_SPEAKING_RATE=1.0
GOOGLE_TTS_TIMEOUT_SECONDS=30
GOOGLE_TRANSLATE_TIMEOUT_SECONDS=30
